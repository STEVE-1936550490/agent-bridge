# AgentBridge Configuration
# Copy this file to config.yaml and fill in your values:
#   cp config.yaml.example config.yaml

upstream:
  # GLM platform API endpoint
  base_url: "https://moma.cmecloud.cn/v1"
  # API key - either set directly or use environment variable expansion
  api_key: "${AGENT_BRIDGE_API_KEY}"
  # Or set directly (NOT recommended for git-tracked files):
  # api_key: "your-api-key-here"

# Provider-aware configuration. Use provider names like `<platform>_<model>`.
active_provider: "moma_glm51"
default_model: "ZHIPU/GLM-5.1"

providers:
  moma_glm51:
    base_url: "https://moma.cmecloud.cn/v1"
    api_key_env: "AGENT_BRIDGE_API_KEY"
    model: "ZHIPU/GLM-5.1"
    provider_api: "openai_chat"       # openai_chat | openai_responses | anthropic_messages
    client_protocol: "codex_responses" # codex_responses | anthropic
    reasoning_mode: "thinking"        # passthrough | thinking | none (GLM 只支持开/关思考)

server:
  host: "0.0.0.0"
  port: 17681

mode: "codex"  # legacy compatibility field: "codex" or "anthropic"

logging:
  level: "INFO"
  format: "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
